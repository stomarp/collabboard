# App
APP_NAME=CollabBoard
APP_ENV=development

# Backend
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=collabboard_dev
POSTGRES_USER=collabboard
POSTGRES_PASSWORD=collabboard

DATABASE_URL=postgresql+psycopg://collabboard:collabboard@localhost:55432/collabboard_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-me-in-development
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
